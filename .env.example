APP_NAME="B2B E-Commerce"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=b2b
DB_USERNAME=root
DB_PASSWORD=

QUEUE_CONNECTION=database
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="${APP_NAME}"

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

SMS_EXPLORER_USERNAME=
SMS_EXPLORER_PASSWORD=
SMS_EXPLORER_FROM=
SMS_EXPLORER_ENDPOINT=

PAYMENT_MAX_AMOUNT=
PAYMENT_REFACTORED_BANK_CONTROLLER=true

ERP_CONNECTION=sqlsrv
ERP_HOST=127.0.0.1
ERP_PORT=1433
ERP_DATABASE=
ERP_USERNAME=
ERP_PASSWORD=
ERP_BASE_URL=

TRANSACTIONS_ONLY=false

LOG_CHANNEL=stack
LOG_LEVEL=debug
FILESYSTEM_DRIVER=local
SESSION_LIFETIME=120
SANCTUM_STATEFUL_DOMAINS=
ASSET_URL=

ERROR_NOTIFICATION_MAIL=

DEFAULT_ADMIN_PASSWORD=change-me
DEFAULT_USER_PASSWORD=change-me